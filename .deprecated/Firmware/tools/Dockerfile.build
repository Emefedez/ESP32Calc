# MicroPython v1.23.0's ESP32 port requires ESP-IDF 5.x.
# Use Espressif's image so the IDF checkout, Python env, and S3 toolchain
# stay in sync instead of rebuilding them by hand.
FROM espressif/idf:v5.0.4

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    git \
    make \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
